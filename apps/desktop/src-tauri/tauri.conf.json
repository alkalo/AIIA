{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIIA",
  "version": "0.1.26",
  "identifier": "com.aiia.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AIIA — Chat & Agents",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/AIIA/**", "$APPLOCALDATA/AIIA/**", "**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg"],
    "resources": {
      "runner-bundle/": "runner-bundle/",
      "update-helper/": "update-helper/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["en-US", "es-ES"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
